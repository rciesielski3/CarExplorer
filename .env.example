# News API (required for news feature)
NEWS_API_KEY=your_news_api_key

# CarImages API (required for car image fallback)
CAR_IMAGES_API_KEY=your_carimages_api_key

# AdMob Android (required for ads)
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-4185040274135926~6045284737
EXPO_PUBLIC_ADMOB_ANDROID_BANNER_ID=ca-app-pub-4185040274135926/4639183818

# Release signing credentials (set via environment or gradle.properties, NOT in .env)
# CAREXPLORER_UPLOAD_STORE_FILE=/path/to/keystore.jks
# CAREXPLORER_UPLOAD_STORE_PASSWORD=your_store_password
# CAREXPLORER_UPLOAD_KEY_ALIAS=your_key_alias
# CAREXPLORER_UPLOAD_KEY_PASSWORD=your_key_password
