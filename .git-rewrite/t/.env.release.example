# Copy this file to .env.release.local and fill it with your local values.
# Do not commit .env.release.local or any keystore file.

EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy
CAREXPLORER_UPLOAD_STORE_FILE=/absolute/path/to/upload-keystore.jks
CAREXPLORER_UPLOAD_STORE_PASSWORD=replace-me
CAREXPLORER_UPLOAD_KEY_ALIAS=replace-me
CAREXPLORER_UPLOAD_KEY_PASSWORD=replace-me
