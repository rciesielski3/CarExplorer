{
  "expo": {
    "name": "CarExplorer",
    "slug": "car-explorer",
    "version": "2.2.2.3",
    "orientation": "portrait",
    "icon": "./assets/images/carexplorer512.png",
    "splash": {
      "image": "./assets/images/carexplorer512.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/carexplorer512.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.adateo.carexplorer",
      "versionCode": 72
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adateo.carexplorer"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "assetBundlePatterns": ["**/*"],
    "plugins": ["expo-font"],
    "extra": {
      "CAR_IMAGES_API_KEY": "${EXPO_PUBLIC_CAR_IMAGES_API_KEY}",
      "CAR_IMAGES_API_SECRET": "${EXPO_PUBLIC_CAR_IMAGES_API_SECRET}"
    }
  }
}
